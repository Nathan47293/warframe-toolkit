{
  "manifest_version": 3,
  "name": "Warframe Dynamic Price Automator",
  "version": "0.32.1",
  "description": "Reads your warframe.market mod listings, finds the cheapest ingame competitor for each, and recommends a -1p undercut gated by a configurable plat/1k endo floor.",
  "permissions": ["notifications", "storage", "alarms"],
  "host_permissions": [
    "https://warframe.market/*",
    "https://api.warframe.market/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://warframe.market/profile/*",
        "https://warframe.market/tools/ducats*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
